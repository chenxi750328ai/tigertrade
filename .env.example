# 复制为 .env 后按需修改（.env 勿提交仓库）
# 综合账户（python src/tiger1.py c ...）必须开启，否则所有真实下单会被本地拒绝，order_log 记为 ALLOW_REAL_TRADING!=1
ALLOW_REAL_TRADING=1

# --- 推 GitHub：chenxi750328ai/tigertrade（与江湖 GITHUB_TOKEN 分开）---
# 任选其一：本文件 或 agentfuture/.env
# TIGERTRADE_GITHUB_PAT=ghp_xxx
# CHENXI750328AI_GITHUB_PAT=ghp_xxx

# --- Leader 本机例行进程（scripts/start_leader_routine_daemon.sh / leader_routine_tick.sh）---
# 每轮例行档位：minimal（仅 pulse+信号）| standard（+DFX 门禁）| heavy（+pytest+轻量 optimize，耗时长）
# LEADER_ROUTINE_PROFILE=standard

# 每轮结束后额外执行的脚本（可选，路径须存在）
# LEADER_ROUTINE_POST_HOOK=/path/to/your_hook.sh

# 通知（可选）
# LEADER_ROUTINE_WEBHOOK_URL=https://your-n8n-or-bot/webhook
# LEADER_ROUTINE_NOTIFY_CMD=curl -fsS -X POST -H "Content-Type: application/json" -d "$LEADER_ROUTINE_JSON" https://...

# 守护进程循环间隔（秒），仅 leader_loop_forever / start_leader_routine_daemon 使用
# LEADER_LOOP_INTERVAL_SEC=900

# 在 standard 下也跑轻量 optimize（与 STATUS 例行一致；约数十秒/轮）
# LEADER_ROUTINE_RUN_OPTIMIZE_LIGHT=1
